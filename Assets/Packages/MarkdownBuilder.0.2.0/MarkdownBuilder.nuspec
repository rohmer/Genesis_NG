<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>MarkdownBuilder</id>
    <version>0.2.0</version>
    <authors>Charles de Vandière</authors>
    <owners>Charles de Vandière</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <iconUrl>https://raw.githubusercontent.com/charlesdevandiere/markdown-builder-dotnet/master/logo.png</iconUrl>
    <description>Markdown builder for .NET Core.</description>
    <repository url="https://github.com/charlesdevandiere/markdown-builder-dotnet" />
    <dependencies>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Dawn.Guard" version="1.11.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>